<div class="section">
  <div class="container" style="max-width: 400px;">
    <h1 class="section__heading">{{ 'customer.login' | t }}</h1>

    {%- form 'customer_login' -%}
      {{ form.errors | default_errors }}

      <div class="form-group">
        <label for="customer-email">{{ 'customer.email' | t }}</label>
        <input type="email" id="customer-email" name="customer[email]" autocomplete="email" required>
      </div>

      <div class="form-group">
        <label for="customer-password">{{ 'customer.password' | t }}</label>
        <input type="password" id="customer-password" name="customer[password]" autocomplete="current-password" required>
      </div>

      <button type="submit" class="btn btn--primary" style="width: 100%;">{{ 'customer.login' | t }}</button>

      <p style="text-align: center; margin-top: 1rem;">
        <a href="/account/register">{{ 'customer.register' | t }}</a>
        &middot;
        <a href="#recover" id="recover-link">{{ 'customer.forgot_password' | t }}</a>
      </p>
    {%- endform -%}

    <div id="recover" style="display: none; margin-top: 2rem;">
      <h2>{{ 'customer.reset_password' | t }}</h2>
      {%- form 'recover_customer_password' -%}
        {{ form.errors | default_errors }}

        <div class="form-group">
          <label for="recover-email">{{ 'customer.email' | t }}</label>
          <input type="email" id="recover-email" name="email" autocomplete="email" required>
        </div>

        <button type="submit" class="btn btn--primary" style="width: 100%;">{{ 'customer.reset_password' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</div>

<script>
  document.getElementById('recover-link').addEventListener('click', function(e) {
    e.preventDefault();
    document.getElementById('recover').style.display = 'block';
  });
</script>
