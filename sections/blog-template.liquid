<section class="section">
  <div class="container">
    <h1 class="section__heading">{{ blog.title }}</h1>

    {%- paginate blog.articles by 6 -%}
      <div class="grid grid--3">
        {%- for article in blog.articles -%}
          <div class="product-card">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="product-card__image">
                {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title }}
              </a>
            {%- endif -%}
            <h3 class="product-card__title">
              <a href="{{ article.url }}">{{ article.title }}</a>
            </h3>
            <p class="product-card__price">{{ article.published_at | date: '%B %d, %Y' }}</p>
            {%- if article.excerpt != blank -%}
              <p style="font-size: 0.9rem; margin-top: 0.5rem;">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}">&laquo; Previous</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}
              <span class="current">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}">Next &raquo;</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog template",
  "tag": "section",
  "settings": []
}
{% endschema %}
