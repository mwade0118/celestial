<footer class="footer">
  {%- comment -%} Hero banner CTA strip {%- endcomment -%}
  <div class="footer__cta">
    <div class="container footer__cta-inner">
      <div class="footer__cta-text">
        <span class="footer__cta-label">{{ section.settings.cta_label }}</span>
        <h3 class="footer__cta-headline">{{ section.settings.cta_headline }}</h3>
      </div>
      {%- form 'customer', id: 'FooterNewsletter', class: 'footer__cta-form' -%}
        <div class="footer__newsletter">
          <input
            type="email"
            name="contact[email]"
            placeholder="Enter your email"
            required
            autocomplete="off"
            class="footer__newsletter-input"
            aria-label="Email address"
          >
          <input type="hidden" name="contact[tags]" value="newsletter">
          <button type="submit" class="footer__newsletter-btn">Subscribe</button>
        </div>
      {%- endform -%}
    </div>
  </div>

  {%- comment -%} Main footer content {%- endcomment -%}
  <div class="footer__main">
    <div class="footer__star-bg" aria-hidden="true">
      <img src="{{ 'staroutline.svg' | asset_url }}" alt="" loading="lazy">
    </div>
    <div class="container footer__grid">
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="Celestial Camouflage">
          <img src="{{ 'script-logo.svg' | asset_url }}" alt="Celestial Camouflage" loading="lazy">
        </a>
        <p class="footer__tagline">{{ section.settings.tagline }}</p>
        <div class="footer__social">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_twitter != blank -%}
            <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X (Twitter)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.51a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.71a8.21 8.21 0 0 0 4.76 1.52V6.69z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- if linklists[section.settings.menu].links.size > 0 -%}
        <div class="footer__column">
          <h4 class="footer__heading">Shop</h4>
          <ul class="footer__nav">
            {%- for link in linklists[section.settings.menu].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- if linklists[section.settings.menu_2].links.size > 0 -%}
        <div class="footer__column">
          <h4 class="footer__heading">{{ section.settings.menu_2_title }}</h4>
          <ul class="footer__nav">
            {%- for link in linklists[section.settings.menu_2].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="footer__column">
        <h4 class="footer__heading">Support</h4>
        <ul class="footer__nav">
          <li><a href="/policies/shipping-policy">Shipping & Returns</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          {%- if section.settings.email != blank -%}
            <li><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></li>
          {%- endif -%}
        </ul>
      </div>
    </div>
  </div>

  {%- comment -%} Bottom bar {%- endcomment -%}
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} Celestial Camouflage. All rights reserved.</p>
      <div class="footer__bottom-links">
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Primary menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Secondary menu"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Secondary menu title",
      "default": "Information"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Premium camouflage apparel for those who stand out."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Newsletter label",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "cta_headline",
      "label": "Newsletter headline",
      "default": "Be the first to know about new drops, exclusives & more."
    }
  ]
}
{% endschema %}
