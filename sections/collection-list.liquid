<section class="section">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="grid grid--3">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <a href="{{ collection.url }}" class="product-card" {{ block.shopify_attributes }}>
          <div class="product-card__image">
            {%- if collection.image -%}
              {{ collection.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection.title }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <h3 class="product-card__title">{{ collection.title }}</h3>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
