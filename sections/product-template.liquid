<section class="section">
  <div class="container">
    <div class="product">
      <div class="product__images">
        {%- for image in product.images limit: 4 -%}
          <div class="product__image-cell">
            {{ image | image_url: width: 800 | image_tag: alt: image.alt, loading: 'lazy' }}
          </div>
        {%- endfor -%}
        {%- assign remaining = 4 | minus: product.images.size -%}
        {%- if remaining > 0 -%}
          {%- for i in (1..remaining) -%}
            <div class="product__image-cell">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="product__info">
        <h1 class="product__title">{{ product.title }}</h1>

        <div class="product__price">
          {%- if product.compare_at_price > product.price -%}
            <s class="product__price-compare">{{ product.compare_at_price | money_without_trailing_zeros }}</s>
          {%- endif -%}
          <span class="product__price-current" data-currency="{{ cart.currency.iso_code }}">{{ product.price | money_without_trailing_zeros }} {{ cart.currency.iso_code }}</span>
        </div>

        {%- form 'product', product -%}
          <div class="product__form">
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-input>

            {%- if product.has_only_default_variant == false -%}
              {%- for option in product.options_with_values -%}
                <div class="product__option">
                  <div class="product__option-values">
                    {%- for value in option.values -%}
                      <button type="button"
                        class="product__variant-btn{% if option.selected_value == value %} is-active{% endif %}"
                        data-option-index="{{ option.position }}"
                        data-value="{{ value }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}

            {%- if section.blocks.size > 0 -%}
              <div class="product__accordions">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'accordion' -%}
                    <div class="accordion" {{ block.shopify_attributes }}>
                      <button type="button" class="accordion__trigger" aria-expanded="false" aria-controls="accordion-{{ block.id }}">
                        <span class="accordion__title">{{ block.settings.heading }}</span>
                        <span class="accordion__icon" aria-hidden="true">&rsaquo;</span>
                      </button>
                      <div class="accordion__content" id="accordion-{{ block.id }}" hidden>
                        <div class="accordion__body rte">
                          {%- if block.settings.use_product_description -%}
                            {{ product.description }}
                          {%- else -%}
                            {{ block.settings.content }}
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="product__add-to-cart-wrapper">
              <button type="submit" class="product__add-to-cart"
                {%- unless product.available %} disabled{% endunless -%}
              >
                {%- if product.available -%}
                  {{ 'products.add_to_cart' | t }}
                {%- else -%}
                  {{ 'products.sold_out' | t }}
                {%- endif -%}
              </button>
              {%- if product.available -%}
                <div class="product__bagman">
                  {% render 'icon-bagman' %}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>

  <script type="application/json" data-product-variants>
    {{ product.variants | json }}
  </script>
</section>

{% schema %}
{
  "name": "Product template",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "checkbox",
          "id": "use_product_description",
          "label": "Use product description as content",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product template",
      "blocks": [
        { "type": "accordion", "settings": { "heading": "GARMENT MEASUREMENTS" } },
        { "type": "accordion", "settings": { "heading": "DETAILS", "use_product_description": true } },
        { "type": "accordion", "settings": { "heading": "CARE AND MAINTENANCE" } }
      ]
    }
  ]
}
{% endschema %}
